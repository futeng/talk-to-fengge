# LiveKit 只负责本机 WebRTC 音频传输
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=local-dev-secret-change-me-32-bytes
AGENT_NAME=talk-to-persona-cloud

# 人格：fengge | steve_jobs | personas/<name>/persona.md
PERSONA_NAME=fengge
AGENT_INSTRUCTIONS=

# 豆包流式语音识别模型 2.0（旧控制台 App ID + Access Token）
DOUBAO_ASR_APP_ID=7446114798
DOUBAO_ASR_ACCESS_TOKEN=
DOUBAO_ASR_RESOURCE_ID=volc.seedasr.sauc.duration
DOUBAO_ASR_END_WINDOW_MS=500
# 新版控制台可改用单一 API Key：
# DOUBAO_ASR_API_KEY=

# DeepSeek V4 Flash（显式关闭 thinking，降低语音首字延迟）
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MAX_TOKENS=100
DEEPSEEK_TEMPERATURE=0.65

# 豆包 V3 双向 WebSocket TTS
DOUBAO_TTS_APP_ID=
DOUBAO_TTS_ACCESS_TOKEN=
# 新版控制台可改用：DOUBAO_TTS_API_KEY=
DOUBAO_TTS_RESOURCE_ID=seed-icl-2.0
DOUBAO_TTS_MODEL=seed-tts-2.0-expressive
DOUBAO_TTS_SPEAKER=
DOUBAO_TTS_SAMPLE_RATE=24000
DOUBAO_TTS_LANGUAGE=zh-cn
DOUBAO_TTS_CONTEXT=

# 推荐：一个 .env.local 同时绑定多个人物，切换 PERSONA_NAME 即可切换音色。
# PERSONA_FENGGE_TTS_SPEAKER=S_xxx
# PERSONA_FENGGE_TTS_RESOURCE_ID=seed-icl-2.0
# PERSONA_FENGGE_TTS_MODEL=seed-tts-2.0-expressive
# PERSONA_FENGGE_TTS_LANGUAGE=zh
# PERSONA_STEVE_JOBS_TTS_SPEAKER=S_xxx
# PERSONA_STEVE_JOBS_TTS_RESOURCE_ID=seed-icl-2.0
# PERSONA_STEVE_JOBS_TTS_MODEL=seed-tts-2.0-expressive
# PERSONA_STEVE_JOBS_TTS_LANGUAGE=en

# 本地 VAD 只做轮次判断和打断，不执行语音识别
VAD_MIN_SPEECH_S=0.20
VAD_MIN_SILENCE_S=0.35
